{
  "version": 2,
  "installCommand": "echo 'Skipping install'",
  "buildCommand": "echo 'Using pre-built bundle'",
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    }
  ]
}
