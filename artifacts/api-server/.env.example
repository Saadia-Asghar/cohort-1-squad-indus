# Set these in Vercel. Never commit a real value to this file.
DATABASE_URL=postgresql://...
JWT_SECRET=replace-with-a-long-random-secret

# Enables real AI replies and OpenAI embeddings.
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional n8n automation bridge. Create a production Webhook trigger in n8n
# and put its URL here. The secret is sent in X-Indus-Webhook-Secret.
N8N_WEBHOOK_URL=https://your-n8n.example/webhook/indus-events
N8N_WEBHOOK_SECRET=replace-with-a-long-random-secret

# WhatsApp Business Cloud API (only after Meta setup is complete).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
