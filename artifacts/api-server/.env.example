# Set these in Vercel. Never commit a real value to this file.
DATABASE_URL=postgresql://...
# Required in production (≥32 chars). Dev falls back to a local placeholder.
JWT_SECRET=replace-with-a-long-random-secret
# Optional one-time pitch seed trigger for POST /api/admin/enrich-demo (Vercel only).
ENRICH_DEMO_SECRET=
# Never set on Vercel unless you intentionally wipe the DB.
# ALLOW_DESTRUCTIVE_SEED=1
FRONTEND_URL=https://cohort-1-squad-indus-sweet-tooth.vercel.app

# Optional Clerk (Google SSO). When unset, native email/password auth is used.
# AUTH_MODE=clerk          — hybrid: Clerk + native JWT both work (recommended)
# AUTH_MODE=legacy         — native only, ignore Clerk on dashboard routes
# AUTH_MODE=clerk-only     — Clerk required; native register/login disabled
AUTH_MODE=clerk
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Embeddings are local (384-dim) by default. No OpenAI key required for the rule+RAG agent.
# OPENAI_API_KEY=  # reserved / unused by current agent path

# Optional HTTPS hosts for pasted receipt URLs (Payments file upload works without this).
RECEIPT_IMAGE_HOSTS=res.cloudinary.com
# Self-host eng.traineddata.gz for deterministic production OCR.
TESSERACT_LANG_PATH=https://your-static-assets.example/tesseract

# Optional n8n automation bridge (order.created, chat.*, payment.advance_reminder,
# billing.upgrade_requested, billing.plan_activated).
# Create a Webhook trigger in n8n and put its URL here.
N8N_WEBHOOK_URL=https://your-n8n.example/webhook/indus-events
N8N_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Optional free Langfuse Hobby tracing — https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Platform subscription billing (free manual flow — no JazzCash API).
# Bakers transfer to your JazzCash/Easypaisa/bank, then WhatsApp you; you activate via POST /api/admin/activate-plan.
# You can also set runtime via POST /api/admin/platform-billing (Bearer JWT_SECRET).
# Production: set real values on Vercel (do not commit them here).
PLATFORM_WHATSAPP=03001234567
PLATFORM_BILLING_NAME=Sweet Tooth
PLATFORM_PAYMENT_DETAILS=JazzCash 03XX-XXXXXXX (Name) · Easypaisa 03XX-XXXXXXX · Bank: XXXX IBAN PK...

# WhatsApp / Instagram (Meta Embedded Signup — complete via Agent Hub, not OAuth redirect).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
META_APP_ID=
META_CONFIG_ID=
TOKEN_ENCRYPTION_KEY=
